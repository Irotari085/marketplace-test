      <section class="checkout-grid">
        <div class="form-card">
          <h3>Р вҖқР С•РЎРғРЎвҖҡР В°Р РҶР С”Р В°</h3>
          <div class="form-group">
            <label class="form-label" for="full-name">Р ВҳР СҳРЎРҸ Р С—Р С•Р В»РЎС“РЎвҖЎР В°РЎвҖҡР ВөР В»РЎРҸ</label>
